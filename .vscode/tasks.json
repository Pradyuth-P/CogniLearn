{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start CogniLearn (Backend + Frontend)",
            "type": "shell",
            "command": "npm start",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}